 .../base-files/lib/upgrade/platform.sh        |   1 +
 .../arm/boot/dts/qcom/qcom-ipq4019-mr9000.dts | 111 ++++++++++++++++++
 target/linux/ipq40xx/image/generic.mk         |  18 +++
 9 files changed, 143 insertions(+), 7 deletions(-)
 create mode 100644 target/linux/ipq40xx/files-6.12/arch/arm/boot/dts/qcom/qcom-ipq4019-mr9000.dts

diff --git a/package/boot/uboot-tools/uboot-envtools/files/ipq40xx b/package/boot/uboot-tools/uboot-envtools/files/ipq40xx
index 6f16491747..fc0ac33334 100644
--- a/package/boot/uboot-tools/uboot-envtools/files/ipq40xx
+++ b/package/boot/uboot-tools/uboot-envtools/files/ipq40xx
@@ -45,7 +45,8 @@ linksys,ea6350v3)
 	;;
 linksys,ea8300|\
 linksys,mr6350|\
-linksys,mr8300)
+linksys,mr8300|\
+linksys,mr9000)
 	ubootenv_add_uci_config "/dev/mtd7" "0x0" "0x40000" "0x20000"
 	;;
 linksys,whw01)
